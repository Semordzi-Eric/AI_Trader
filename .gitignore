# =============================================================================
# AI Trader — .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd
*.pyo

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
MANIFEST

# Virtual environments
.venv/
venv/
env/
.env/
ENV/

# ---------------------------------------------------------------------------
# Secrets & local config
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
secrets.yaml
secrets.yml
*.secret

# ---------------------------------------------------------------------------
# Project artifacts (generated at runtime — never commit)
# ---------------------------------------------------------------------------

# All runtime artifacts (models, data, reports, logs)
artifacts/**
!artifacts/
!artifacts/.gitkeep

# Data cache (legacy path referenced in older gitignore conversations)
data_cache/

# ---------------------------------------------------------------------------
# Testing / coverage
# ---------------------------------------------------------------------------
.pytest_cache/
.coverage
coverage.xml
htmlcov/
*.lcov

# ---------------------------------------------------------------------------
# Jupyter
# ---------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb

# ---------------------------------------------------------------------------
# Type checking / linting
# ---------------------------------------------------------------------------
.mypy_cache/
.ruff_cache/
.pytype/

# ---------------------------------------------------------------------------
# IDEs & editors
# ---------------------------------------------------------------------------
.idea/
.vscode/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# OS
# ---------------------------------------------------------------------------
desktop.ini
